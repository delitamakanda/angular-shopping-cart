{
  "name": "angular-shopping-cart",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:fr": "ng serve --configuration fr",
    "start:en": "ng serve --configuration en",
    "start:ko": "ng serve --configuration ko",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "extract-i18n": "ng extract-i18n --output-path src/locale --format xlf",
    "localize:fr": "ng extract-i18n --output-path src/locale --format xlf --out-file messages.fr.xlf",
    "localize:en": "ng extract-i18n --output-path src/locale --format xlf --out-file messages.en.xlf",
    "localize:ko": "ng extract-i18n --output-path src/locale --format xlf --out-file messages.ko.xlf"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.6",
    "@angular/cdk": "^22.0.4",
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/material": "^22.0.4",
    "@angular/platform-browser": "^22.0.6",
    "@angular/platform-browser-dynamic": "^22.0.6",
    "@angular/router": "^22.0.6",
    "@angular/service-worker": "^22.0.6",
    "notyf": "^3.10.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "@angular/localize": "^22.0.6",
    "@mcp-b/webmcp-polyfill": "^4.0.0",
    "@types/jasmine": "~4.3.0",
    "@vitest/browser-preview": "^4.1.8",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~4.6.0",
    "jsdom": "^29.1.1",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~6.0.3",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": "24.15.0",
    "npm": "11.12.1"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "esbuild@0.27.7": true,
    "lmdb@3.5.4": true,
    "msgpackr-extract@3.0.4": true,
    "esbuild@0.28.1": true
  }
}
